---
const services = [
	{ href: '/branding', label: 'Branding e Identidad de Marca' },
	{ href: '/clinica-de-marketing', label: 'Clínica de Marketing' },
	{ href: '/cursos', label: 'Cursos' },
	{ href: '/ecommerce', label: 'E-commerce' },
	{ href: '/estudio-de-mercado', label: 'Estudio de Mercado' },
	{ href: '/ia', label: 'Inteligencia Artificial' },
	{ href: '/paquetes', label: 'Paquetes' },
];
---

<footer class='border-t border-brand-main/10 bg-white/60'>
	<div class='container-brand grid gap-12 py-16 md:grid-cols-4'>
		<div>
			<img src='/images/brand/LOGO.webp' alt='Twinbox Agency' class='h-12 w-auto rounded-sm' />
			<p class='mt-4 max-w-xs text-sm leading-relaxed text-brand-main/80'>
				Estrategia, creatividad y resultados para marcas que buscan crecimiento real en México.
			</p>
		</div>

		<div>
			<h3 class='font-heading text-lg'>Navegación</h3>
			<ul class='mt-4 space-y-2 text-sm'>
				<li><a href='/' class='hover:text-brand-accent'>Inicio</a></li>
				<li><a href='/nosotros' class='hover:text-brand-accent'>Nosotros</a></li>
				<li><a href='/portafolio' class='hover:text-brand-accent'>Portafolio</a></li>
				<li><a href='/blog' class='hover:text-brand-accent'>Blog</a></li>
				<li><a href='/contacto' class='hover:text-brand-accent'>Contacto</a></li>
			</ul>
		</div>

		<div>
			<h3 class='font-heading text-lg'>Servicios</h3>
			<ul class='mt-4 space-y-2 text-sm'>
				{services.map((service) => (
					<li><a href={service.href} class='hover:text-brand-accent'>{service.label}</a></li>
				))}
			</ul>
		</div>

		<div>
			<h3 class='font-heading text-lg'>Contacto</h3>
			<ul class='mt-4 space-y-2 text-sm text-brand-main/90'>
				<li><a href='mailto:twinboxmex@gmail.com' class='hover:text-brand-accent'>twinboxmex@gmail.com</a></li>
				<li><a href='tel:+529878004033' class='hover:text-brand-accent'>+52 987 800 4033</a></li>
				<li><a href='tel:+529871116712' class='hover:text-brand-accent'>+52 987 111 6712</a></li>
				<li class='pt-2'>
					<a href='https://www.facebook.com/TwinboxMexico' target='_blank' rel='noreferrer' class='mr-4 hover:text-brand-accent'>Facebook</a>
					<a href='https://www.instagram.com/twinboxmexico/' target='_blank' rel='noreferrer' class='mr-4 hover:text-brand-accent'>Instagram</a>
					<a href='https://tiktok.com/@twinbox.publicidad' target='_blank' rel='noreferrer' class='hover:text-brand-accent'>TikTok</a>
				</li>
			</ul>
		</div>
	</div>
	<div class='border-t border-brand-main/10 py-5 text-center text-xs text-brand-main/70'>
		© 2026 Twinbox Agency. Todos los derechos reservados.
	</div>
</footer>
