---
import ServiceLayout from '../layouts/ServiceLayout.astro';
---

<ServiceLayout
	title='Paquetes de Marketing Digital'
	description='Planes integrales con equipo multidisciplinario para escalar presencia, interacción y ventas.'
>
	<div class='grid gap-6 xl:grid-cols-3'>
		<article class='rounded-2xl border border-brand-main/10 bg-white/70 p-7'>
			<h2 class='font-heading text-2xl'>Paquete Básico</h2>
			<p class='mt-3 text-sm text-brand-main/80'>Presencia digital + contenido + publicidad Meta.</p>
			<p class='mt-6 text-2xl font-semibold text-brand-accent'>$20,000 MXN / mes</p>
		</article>
		<article class='rounded-2xl border border-brand-main/10 bg-white/70 p-7'>
			<h2 class='font-heading text-2xl'>Paquete Intermedio</h2>
			<p class='mt-3 text-sm text-brand-main/80'>Más contenido, Google + Meta Ads y blog mensual.</p>
			<p class='mt-6 text-2xl font-semibold text-brand-accent'>$25,000 MXN / mes</p>
		</article>
		<article class='rounded-2xl border border-brand-main/10 bg-white/70 p-7'>
			<h2 class='font-heading text-2xl'>Departamento Completo</h2>
			<p class='mt-3 text-sm text-brand-main/80'>Equipo completo de marketing y mantenimiento web.</p>
			<p class='mt-6 text-2xl font-semibold text-brand-accent'>$40,000 MXN / mes</p>
		</article>
	</div>
</ServiceLayout>
