---
export const prerender = false;
import '../../styles/global.css';
---

<!doctype html>
<html lang='es'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1.0' />
		<title>Dashboard Blog | Twinbox</title>
	</head>
	<body class='bg-brand-bg text-brand-main'>
		<main class='container-brand max-w-none py-12 lg:w-[60vw]'>
			<header class='mb-8 flex flex-wrap items-center justify-between gap-4'>
				<div>
					<p class='text-xs font-semibold uppercase tracking-[0.24em] text-brand-accent'>Dashboard</p>
					<h1 class='mt-2 font-heading text-4xl'>Administrador de Blog</h1>
				</div>
				<div class='flex items-center gap-2'>
					<button id='change-password-btn' class='hidden rounded-full border border-brand-main/20 px-4 py-2 text-sm'>Cambiar contraseña</button>
					<button id='logout-btn' class='hidden rounded-full border border-brand-main/20 px-4 py-2 text-sm'>Cerrar sesión</button>
				</div>
			</header>

			<section id='supabase-warning' class='mb-6 hidden rounded-2xl border border-red-300 bg-red-50 p-4 text-sm text-red-700'>
				Configura `PUBLIC_SUPABASE_URL` y `PUBLIC_SUPABASE_ANON_KEY` en `.env` para usar el dashboard.
			</section>

			<section id='auth-view' class='max-w-md rounded-3xl border border-brand-main/10 bg-white/70 p-6 shadow-soft'>
				<h2 class='font-heading text-2xl'>Iniciar sesión</h2>
				<p class='mt-2 text-sm text-brand-main/80'>Acceso para administración de contenidos del blog.</p>
				<form id='auth-form' method='post' action='javascript:void(0)' class='mt-6 space-y-3'>
					<input id='auth-email' type='email' required placeholder='Email' class='w-full rounded-xl border border-brand-main/15 bg-brand-bg px-4 py-3 text-sm outline-none focus:border-brand-accent' />
					<input id='auth-password' type='password' required placeholder='Contraseña' class='w-full rounded-xl border border-brand-main/15 bg-brand-bg px-4 py-3 text-sm outline-none focus:border-brand-accent' />
					<button id='auth-submit' type='button' class='w-full rounded-full bg-brand-accent px-4 py-3 text-sm font-semibold uppercase tracking-wide text-white'>Entrar</button>
					<button id='signup-submit' type='button' class='hidden w-full rounded-full border border-brand-main/25 px-4 py-3 text-xs font-semibold uppercase tracking-wide'>Crear acceso inicial</button>
				</form>
				<p id='auth-error' class='mt-3 hidden rounded-xl border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-700'></p>
			</section>

			<section id='dashboard-view' class='hidden'>
				<div class='grid gap-6 lg:grid-cols-[280px,1fr]'>
					<aside class='rounded-3xl border border-brand-main/10 bg-white/80 p-5 shadow-soft lg:sticky lg:top-6 lg:h-fit'>
						<p class='text-[11px] font-semibold uppercase tracking-[0.22em] text-brand-accent'>Panel</p>
						<nav class='mt-4 space-y-2'>
							<button type='button' data-tab-trigger='editor' class='admin-tab-trigger flex w-full items-center justify-between rounded-2xl border border-brand-main/15 bg-brand-bg px-4 py-3 text-left text-sm font-medium text-brand-main transition hover:border-brand-accent/60 hover:text-brand-accent'>
								<span>Editor de Post</span>
								<span class='text-xs uppercase tracking-[0.12em]'>01</span>
							</button>
							<button type='button' data-tab-trigger='posts' class='admin-tab-trigger flex w-full items-center justify-between rounded-2xl border border-brand-main/15 bg-brand-bg px-4 py-3 text-left text-sm font-medium text-brand-main transition hover:border-brand-accent/60 hover:text-brand-accent'>
								<span>Listado de Posts</span>
								<span class='text-xs uppercase tracking-[0.12em]'>02</span>
							</button>
						</nav>
					</aside>

					<div class='space-y-6'>
						<section data-tab-panel='editor' class='admin-tab-panel rounded-3xl border border-brand-main/10 bg-white/70 p-6 shadow-soft'>
							<h2 class='font-heading text-2xl'>Editor</h2>
							<p class='mt-2 text-sm text-brand-main/75'>Crea o actualiza contenido del blog.</p>
							<form id='post-form' class='mt-5'>
								<input id='post-id' type='hidden' />
								<div class='grid gap-3 md:grid-cols-2'>
									<input id='post-title' required placeholder='Título' class='rounded-xl border border-brand-main/15 bg-brand-bg px-4 py-3 text-sm outline-none focus:border-brand-accent md:col-span-2' />
									<input id='post-slug' required placeholder='Slug' class='rounded-xl border border-brand-main/15 bg-brand-bg px-4 py-3 text-sm outline-none focus:border-brand-accent' />
									<input id='post-author' required placeholder='Autor' class='rounded-xl border border-brand-main/15 bg-brand-bg px-4 py-3 text-sm outline-none focus:border-brand-accent' />
									<input id='post-image' placeholder='Imagen destacada URL' class='rounded-xl border border-brand-main/15 bg-brand-bg px-4 py-3 text-sm outline-none focus:border-brand-accent md:col-span-2' />
									<div class='md:col-span-2 rounded-2xl border border-brand-main/10 bg-brand-bg p-3'>
										<label for='post-image-file' class='mb-2 block text-xs font-semibold uppercase tracking-[0.15em] text-brand-accent'>Subir imagen destacada</label>
										<div class='flex flex-wrap items-center gap-2'>
											<input id='post-image-file' type='file' accept='image/*' class='block text-xs' />
											<button id='upload-image-btn' type='button' class='rounded-full border border-brand-main/20 px-4 py-2 text-xs font-semibold uppercase tracking-[0.08em]'>Subir imagen</button>
										</div>
									</div>
									<textarea id='post-description' required rows='3' placeholder='Descripción' class='rounded-xl border border-brand-main/15 bg-brand-bg px-4 py-3 text-sm outline-none focus:border-brand-accent md:col-span-2'></textarea>
									<select id='post-status' class='rounded-xl border border-brand-main/15 bg-brand-bg px-4 py-3 text-sm outline-none focus:border-brand-accent'>
										<option value='draft'>Borrador</option>
										<option value='published'>Publicado</option>
									</select>
									<input id='post-published-at' type='datetime-local' class='rounded-xl border border-brand-main/15 bg-brand-bg px-4 py-3 text-sm outline-none focus:border-brand-accent' />
								</div>
								<label for='content-editor' class='mt-5 block text-xs font-semibold uppercase tracking-[0.18em] text-brand-accent'>Contenido</label>
								<textarea id='content-editor'></textarea>
								<div class='mt-5 flex flex-wrap gap-3'>
									<button type='submit' class='rounded-full bg-brand-accent px-5 py-3 text-xs font-semibold uppercase tracking-[0.1em] text-white'>Guardar post</button>
									<button id='new-post-btn' type='button' class='rounded-full border border-brand-main/20 px-5 py-3 text-xs font-semibold uppercase tracking-[0.1em]'>Nuevo</button>
								</div>
							</form>
						</section>

						<section data-tab-panel='posts' class='admin-tab-panel hidden rounded-3xl border border-brand-main/10 bg-white/70 p-6 shadow-soft'>
							<h2 class='font-heading text-2xl'>Publicaciones</h2>
							<p class='mt-2 text-sm text-brand-main/75'>Haz click en “Editar” para cargar el post en el formulario.</p>
							<div id='posts-list' class='mt-5 space-y-3'></div>
						</section>
					</div>
				</div>
			</section>

			<p id='status-msg' class='mt-3 text-sm text-brand-main/80'></p>
		</main>

		<script is:inline define:vars={{
			supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL ?? '',
			supabaseAnonKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '',
			supabaseStorageBucket: import.meta.env.PUBLIC_SUPABASE_STORAGE_BUCKET ?? 'blog-images',
			tinyMceKey: import.meta.env.PUBLIC_TINYMCE_API_KEY ?? 'vw1ypnbl6ql8xs11n5r66qpu9057j3z65jcc2xfufsx3auq7',
		}}>

			(async () => {
				const warning = document.getElementById('supabase-warning');
				const authView = document.getElementById('auth-view');
				const dashboardView = document.getElementById('dashboard-view');
				const authForm = document.getElementById('auth-form');
				const postForm = document.getElementById('post-form');
				const uploadImageBtn = document.getElementById('upload-image-btn');
				const imageFileInput = document.getElementById('post-image-file');
				const postsList = document.getElementById('posts-list');
				const logoutBtn = document.getElementById('logout-btn');
				const changePasswordBtn = document.getElementById('change-password-btn');
				const statusMsg = document.getElementById('status-msg');
				const authError = document.getElementById('auth-error');
				const tabTriggers = Array.from(document.querySelectorAll('[data-tab-trigger]'));
				const tabPanels = Array.from(document.querySelectorAll('[data-tab-panel]'));

				const setStatus = (message, isError = false) => {
					if (!statusMsg) return;
					statusMsg.textContent = message;
					statusMsg.style.color = isError ? '#b42318' : '#4f4d4d';
				};

				const setAuthError = (message = '') => {
					if (!authError) return;
					authError.textContent = message;
					authError.classList.toggle('hidden', !message);
				};

				const withTimeout = (promise, ms, timeoutMessage) =>
					Promise.race([
						promise,
						new Promise((_, reject) => {
							setTimeout(() => reject(new Error(timeoutMessage)), ms);
						}),
					]);

				const friendlyAuthMessage = (message = '') => {
					if (!message) return 'No se pudo iniciar sesión.';
					const normalized = message.toLowerCase();
					if (normalized.includes('invalid login credentials')) {
						return 'Credenciales inválidas. Verifica email y contraseña.';
					}
					if (normalized.includes('email not confirmed')) {
						return 'Tu correo no está confirmado. Activa Auto Confirm en Supabase o confirma el usuario.';
					}
					return message;
				};

				const SESSION_KEY = 'tb_admin_session';
				const MAX_SESSION_MS = 1000 * 60 * 60 * 12;

				const readSession = () => {
					try {
						const raw = localStorage.getItem(SESSION_KEY);
						if (!raw) return null;
						return JSON.parse(raw);
					} catch {
						return null;
					}
				};

				const saveSession = (payload, preserveHardExpiry = false) => {
					const existing = readSession();
					const now = Date.now();
					const expiresAtMs = Number(payload.expires_at ?? 0) > 0 ? Number(payload.expires_at) * 1000 : now + 60 * 60 * 1000;
					const hardExpiresAt = preserveHardExpiry && existing?.hard_expires_at ? existing.hard_expires_at : now + MAX_SESSION_MS;
					const session = {
						access_token: payload.access_token,
						refresh_token: payload.refresh_token,
						expires_at: expiresAtMs,
						hard_expires_at: hardExpiresAt,
						email: payload.user?.email || existing?.email || '',
					};
					localStorage.setItem(SESSION_KEY, JSON.stringify(session));
					return session;
				};

				const clearSession = () => {
					localStorage.removeItem(SESSION_KEY);
				};

				const setActiveTab = (tabName = 'editor') => {
					tabPanels.forEach((panel) => {
						const isActive = panel.getAttribute('data-tab-panel') === tabName;
						panel.classList.toggle('hidden', !isActive);
					});

					tabTriggers.forEach((trigger) => {
						const isActive = trigger.getAttribute('data-tab-trigger') === tabName;
						trigger.classList.toggle('border-brand-accent', isActive);
						trigger.classList.toggle('bg-brand-accent', isActive);
						trigger.classList.toggle('bg-brand-bg', !isActive);
						trigger.classList.toggle('text-white', isActive);
						trigger.classList.toggle('text-brand-main', !isActive);
						trigger.classList.toggle('hover:border-brand-accent/60', !isActive);
						trigger.classList.toggle('hover:text-brand-accent', !isActive);
					});
				};

				if (!supabaseUrl || !supabaseAnonKey) {
					warning?.classList.remove('hidden');
					authView?.classList.add('hidden');
					return;
				}

				let supabase = null;

				const ensureSupabase = async () => {
					if (supabase) return supabase;
					if (!window.supabase?.createClient) {
						await withTimeout(
							new Promise((resolve, reject) => {
								const script = document.createElement('script');
								script.src = 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js';
								script.onload = resolve;
								script.onerror = reject;
								document.head.appendChild(script);
							}),
							8000,
							'TIMEOUT_SUPABASE_CDN'
						);
					}

					supabase = window.supabase.createClient(supabaseUrl, supabaseAnonKey, {
						auth: {
							persistSession: true,
							autoRefreshToken: true,
							detectSessionInUrl: false,
						},
					});
					return supabase;
				};

				const fields = {
					id: document.getElementById('post-id'),
					title: document.getElementById('post-title'),
					slug: document.getElementById('post-slug'),
					author: document.getElementById('post-author'),
					description: document.getElementById('post-description'),
					image: document.getElementById('post-image'),
					status: document.getElementById('post-status'),
					publishedAt: document.getElementById('post-published-at'),
				};

				const toLocalDatetime = (isoString) => {
					if (!isoString) return '';
					const date = new Date(isoString);
					const offset = date.getTimezoneOffset();
					const local = new Date(date.getTime() - offset * 60 * 1000);
					return local.toISOString().slice(0, 16);
				};

				const slugify = (value) =>
					value
						.toLowerCase()
						.normalize('NFD')
						.replace(/[\u0300-\u036f]/g, '')
						.replace(/[^a-z0-9\s-]/g, '')
						.trim()
						.replace(/\s+/g, '-');

				fields.title?.addEventListener('input', () => {
					if (!fields.id.value) fields.slug.value = slugify(fields.title.value);
				});

				const loadTinyMce = async () => {
					if (window.tinymce) return;
					await new Promise((resolve, reject) => {
						const script = document.createElement('script');
						script.src = `https://cdn.tiny.cloud/1/${tinyMceKey}/tinymce/7/tinymce.min.js`;
						script.referrerPolicy = 'origin';
						script.onload = resolve;
						script.onerror = reject;
						document.head.appendChild(script);
					});

					await window.tinymce.init({
						selector: '#content-editor',
						height: 360,
						menubar: false,
						plugins: 'anchor autolink charmap codesample emoticons image link lists media table visualblocks wordcount code',
						toolbar:
							'undo redo | styles | bold italic underline | alignleft aligncenter alignright | bullist numlist | link image media | table code',
						content_style:
							"body { font-family: 'Poppins', sans-serif; color: #4f4d4d; background: #f3f6f9; font-size: 16px; line-height: 1.8; padding: 18px; } h1,h2,h3,h4 { font-family: 'Raleway', sans-serif; color: #4f4d4d; } a { color: #829240; }",
					});
				};

				const openDashboard = async () => {
					authView?.classList.add('hidden');
					dashboardView?.classList.remove('hidden');
					logoutBtn?.classList.remove('hidden');
					changePasswordBtn?.classList.remove('hidden');

					try {
						await withTimeout(loadTinyMce(), 12000, 'TIMEOUT_TINYMCE');
					} catch (error) {
						console.error('No se pudo cargar TinyMCE:', error);
						setStatus('Sesion iniciada, pero no se pudo cargar el editor visual. Recarga la pagina.', true);
					}

					try {
						await withTimeout(loadPosts(), 12000, 'TIMEOUT_POSTS');
					} catch (error) {
						console.error('No se pudieron cargar los posts:', error);
						setStatus('Sesion iniciada, pero no se pudieron cargar los posts. Verifica la red y permisos de Supabase.', true);
					}
				};

				const resetForm = () => {
					fields.id.value = '';
					fields.title.value = '';
					fields.slug.value = '';
					fields.author.value = '';
					fields.description.value = '';
					fields.image.value = '';
					fields.status.value = 'draft';
					fields.publishedAt.value = '';
					window.tinymce?.get('content-editor')?.setContent('');
				};

				const fillForm = (post) => {
					fields.id.value = post.id;
					fields.title.value = post.title;
					fields.slug.value = post.slug;
					fields.author.value = post.author_name;
					fields.description.value = post.description;
					fields.image.value = post.cover_image || '';
					fields.status.value = post.status;
					fields.publishedAt.value = toLocalDatetime(post.published_at);
					window.tinymce?.get('content-editor')?.setContent(post.content || '');
					setActiveTab('editor');
				};

				const renderPosts = (posts) => {
					if (!postsList) return;
					postsList.innerHTML = '';
					if (!posts.length) {
						postsList.innerHTML = '<p class="text-sm text-brand-main/70">Sin publicaciones aún.</p>';
						return;
					}

					posts.forEach((post) => {
						const article = document.createElement('article');
						article.className = 'rounded-2xl border border-brand-main/10 bg-brand-bg p-4';
						article.innerHTML = `
							<p class="text-[11px] uppercase tracking-[0.16em] text-brand-accent">${post.status}</p>
							<h3 class="mt-1 font-heading text-lg">${post.title}</h3>
							<p class="mt-1 text-xs text-brand-main/70">/${post.slug}</p>
							<div class="mt-3 flex gap-2">
								<button class="edit-btn rounded-full border border-brand-main/20 px-3 py-1 text-xs">Editar</button>
								<button class="delete-btn rounded-full border border-red-300 px-3 py-1 text-xs text-red-600">Eliminar</button>
							</div>
						`;

						article.querySelector('.edit-btn')?.addEventListener('click', () => fillForm(post));
						article.querySelector('.delete-btn')?.addEventListener('click', async () => {
							if (!confirm(`¿Eliminar "${post.title}"?`)) return;
							const client = await ensureSupabase();
							const { error } = await client.from('blog_posts').delete().eq('id', post.id);
							if (error) return setStatus(error.message, true);
							setStatus('Post eliminado.');
							await loadPosts();
							if (fields.id.value === post.id) resetForm();
						});
						postsList.appendChild(article);
					});
				};

				const loadPosts = async () => {
					const client = await ensureSupabase();
					const { data, error } = await client
						.from('blog_posts')
						.select('id,slug,title,description,content,cover_image,author_name,status,published_at,updated_at')
						.order('updated_at', { ascending: false });
					if (error) return setStatus(error.message, true);
					renderPosts(data ?? []);
				};

				const loginViaRest = async (email, password) => {
					const response = await withTimeout(
						fetch(`${supabaseUrl}/auth/v1/token?grant_type=password`, {
							method: 'POST',
							headers: {
								apikey: supabaseAnonKey,
								Authorization: `Bearer ${supabaseAnonKey}`,
								'Content-Type': 'application/json',
							},
							body: JSON.stringify({ email, password }),
						}),
						12000,
						'TIMEOUT_LOGIN'
					);

					let payload = {};
					try {
						payload = await response.json();
					} catch {
						payload = {};
					}

					if (!response.ok) {
						const message = payload.msg || payload.error_description || payload.error || 'LOGIN_FAILED';
						throw new Error(String(message));
					}

					return payload;
				};

				const refreshSessionViaRest = async (refreshToken) => {
					const response = await withTimeout(
						fetch(`${supabaseUrl}/auth/v1/token?grant_type=refresh_token`, {
							method: 'POST',
							headers: {
								apikey: supabaseAnonKey,
								Authorization: `Bearer ${supabaseAnonKey}`,
								'Content-Type': 'application/json',
							},
							body: JSON.stringify({ refresh_token: refreshToken }),
						}),
						12000,
						'TIMEOUT_REFRESH'
					);

					const payload = await response.json();
					if (!response.ok) {
						const message = payload.msg || payload.error_description || payload.error || 'REFRESH_FAILED';
						throw new Error(String(message));
					}

					return payload;
				};

				const getValidSession = async () => {
					const session = readSession();
					if (!session?.access_token) return null;
					const now = Date.now();

					if (session.hard_expires_at && now > session.hard_expires_at) {
						clearSession();
						return null;
					}

					if (session.expires_at && now < session.expires_at - 15000) {
						return session;
					}

					if (!session.refresh_token) {
						clearSession();
						return null;
					}

					const refreshed = await refreshSessionViaRest(session.refresh_token);
					return saveSession(refreshed, true);
				};

				const uploadFeaturedImage = async (file) => {
					const session = await getValidSession();
					if (!session?.access_token) {
						throw new Error('Tu sesion expiro. Vuelve a iniciar sesion para subir imagenes.');
					}

					const formData = new FormData();
					formData.append('file', file);

					const response = await withTimeout(
						fetch('/api/admin/upload-image', {
							method: 'POST',
							headers: {
								Authorization: `Bearer ${session.access_token}`,
							},
							body: formData,
						}),
						20000,
						'TIMEOUT_UPLOAD_IMAGE'
					);

					if (!response.ok) {
						let payload = {};
						try {
							payload = await response.json();
						} catch {
							payload = {};
						}
						const rawMessage = String(payload.message || payload.error || '');
						const message =
							rawMessage.toLowerCase().includes('bucket not found')
								? `Bucket no encontrado: ${supabaseStorageBucket}. Crea ese bucket en Supabase Storage o define PUBLIC_SUPABASE_STORAGE_BUCKET con un bucket existente.`
								: rawMessage || 'No se pudo subir la imagen.';
						throw new Error(String(message));
					}

					const payload = await response.json();
					if (!payload?.url) throw new Error('No se recibio URL publica de la imagen.');
					return payload.url;
				};

				const handleAuthLogin = async () => {
					setAuthError('');
					const loginBtn = document.getElementById('auth-submit');
					if (loginBtn) loginBtn.disabled = true;
					const loginWatchdog = setTimeout(() => {
						setAuthError('El inicio de sesion quedo bloqueado por red o extensiones del navegador. Prueba en incognito sin extensiones.');
						setStatus('Inicio de sesion cancelado por timeout.', true);
						if (loginBtn) loginBtn.disabled = false;
					}, 15000);
					const email = String(document.getElementById('auth-email')?.value || '').trim().toLowerCase();
					const password = String(document.getElementById('auth-password')?.value || '');

					if (!email || !password) {
						const message = 'Completa email y contraseña.';
						setAuthError(message);
						setStatus(message, true);
						if (loginBtn) loginBtn.disabled = false;
						return false;
					}

					try {
						const tokenData = await loginViaRest(email, password);
						if (tokenData?.access_token) {
							saveSession(tokenData);
						}
						await openDashboard();
						setStatus('Sesion iniciada correctamente.');
					} catch (error) {
						const message =
							error instanceof Error && error.message === 'TIMEOUT_SUPABASE_INIT'
								? 'No se pudo inicializar Supabase. Revisa red, bloqueadores y recarga con Ctrl+F5.'
								: error instanceof Error && error.message === 'TIMEOUT_LOGIN'
								? 'El login tardo demasiado y fue cancelado. Desactiva bloqueadores/extensiones, recarga con Ctrl+F5 y prueba otra vez.'
								: error instanceof Error && error.message === 'TIMEOUT_REFRESH'
								? 'No se pudo refrescar la sesion. Vuelve a iniciar sesion.'
								: error instanceof Error && /cdn|supabase|load|script/i.test(error.message)
									? 'No se pudo cargar Supabase desde la red. Revisa internet, desactiva bloqueadores y recarga con Ctrl+F5.'
									: friendlyAuthMessage(error instanceof Error ? error.message : 'Error inesperado al iniciar sesion.');
						setAuthError(message);
						setStatus(message, true);
						console.error(error);
					} finally {
						clearTimeout(loginWatchdog);
						if (loginBtn) loginBtn.disabled = false;
					}

					return false;
				};

				const handleAuthSignup = async () => {
					setAuthError('');
					const client = await ensureSupabase();
					const email = document.getElementById('auth-email')?.value;
					const password = document.getElementById('auth-password')?.value;
					const { error } = await client.auth.signUp({ email, password });
					if (error) {
						setAuthError(error.message);
						setStatus(error.message, true);
						return false;
					}
					setStatus('Cuenta creada. Revisa tu correo para confirmar y luego inicia sesión.');
					setAuthError('Cuenta creada. Si no ves el correo, revisa spam.');
					return false;
				};

				authForm?.addEventListener('submit', async (event) => {
					event.preventDefault();
					setStatus('Validando credenciales...');
					await handleAuthLogin();
				});

				document.getElementById('auth-submit')?.addEventListener('click', async (event) => {
					event.preventDefault();
					setStatus('Validando credenciales...');
					await handleAuthLogin();
				});

				document.getElementById('signup-submit')?.addEventListener('click', async () => {
					await handleAuthSignup();
				});

				uploadImageBtn?.addEventListener('click', async () => {
					const file = imageFileInput?.files?.[0];
					if (!file) {
						setStatus('Selecciona una imagen antes de subir.', true);
						return;
					}

					uploadImageBtn.disabled = true;
					setStatus('Subiendo imagen destacada...');
					try {
						const imageUrl = await uploadFeaturedImage(file);
						fields.image.value = imageUrl;
						setStatus('Imagen subida correctamente y asignada al campo URL.');
					} catch (error) {
						setStatus(error instanceof Error ? error.message : 'No se pudo subir la imagen.', true);
					} finally {
						uploadImageBtn.disabled = false;
					}
				});

				logoutBtn?.addEventListener('click', async () => {
					clearSession();
					try {
						const client = await ensureSupabase();
						await client.auth.signOut();
					} catch {
						// Ignore SDK signout errors if CDN is blocked.
					}
					setStatus('Sesión cerrada.');
					authView?.classList.remove('hidden');
					dashboardView?.classList.add('hidden');
					logoutBtn?.classList.add('hidden');
					changePasswordBtn?.classList.add('hidden');
				});

				changePasswordBtn?.addEventListener('click', async () => {
					const nextPassword = prompt('Nueva contraseña (minimo 8 caracteres):');
					if (!nextPassword) return;
					if (nextPassword.length < 8) {
						setStatus('La nueva contraseña debe tener al menos 8 caracteres.', true);
						return;
					}

					try {
						const session = await getValidSession();
						if (!session?.access_token) {
							setStatus('Tu sesion expiro. Vuelve a iniciar sesion.', true);
							return;
						}

						const response = await withTimeout(
							fetch(`${supabaseUrl}/auth/v1/user`, {
								method: 'PUT',
								headers: {
									apikey: supabaseAnonKey,
									Authorization: `Bearer ${session.access_token}`,
									'Content-Type': 'application/json',
								},
								body: JSON.stringify({ password: nextPassword }),
							}),
							12000,
							'TIMEOUT_CHANGE_PASSWORD'
						);

						if (!response.ok) {
							let payload = {};
							try {
								payload = await response.json();
							} catch {
								payload = {};
							}
							throw new Error(payload.msg || payload.error_description || payload.error || 'No se pudo cambiar la contraseña.');
						}

						setStatus('Contraseña actualizada correctamente.');
					} catch (error) {
						setStatus(error instanceof Error ? error.message : 'No se pudo cambiar la contraseña.', true);
					}
				});

				postForm?.addEventListener('submit', async (event) => {
					event.preventDefault();
					const content = window.tinymce?.get('content-editor')?.getContent() || '';
					const payload = {
						title: fields.title.value.trim(),
						slug: slugify(fields.slug.value.trim()),
						description: fields.description.value.trim(),
						content,
						cover_image: fields.image.value.trim() || null,
						author_name: fields.author.value.trim(),
						status: fields.status.value,
						published_at: fields.publishedAt.value ? new Date(fields.publishedAt.value).toISOString() : null,
					};
					const client = await ensureSupabase();
					const { error } = await client.from('blog_posts').upsert(
						fields.id.value ? { id: fields.id.value, ...payload } : payload,
						{ onConflict: 'slug' }
					);
					if (error) return setStatus(error.message, true);
					setStatus('Post guardado correctamente.');
					await loadPosts();
					if (!fields.id.value) resetForm();
				});

				document.getElementById('new-post-btn')?.addEventListener('click', resetForm);

				tabTriggers.forEach((trigger) => {
					trigger.addEventListener('click', () => {
						setActiveTab(trigger.getAttribute('data-tab-trigger') || 'editor');
					});
				});

				setActiveTab('editor');

				try {
					const session = await getValidSession();
					if (session?.access_token) {
						await openDashboard();
					}
				} catch (error) {
					console.error('Inicializacion del dashboard fallo:', error);
					setAuthError('No se pudo inicializar el dashboard. Recarga con Ctrl+F5.');
					setStatus('No se pudo inicializar el dashboard.', true);
				}
			})();
		</script>
	</body>
</html>
