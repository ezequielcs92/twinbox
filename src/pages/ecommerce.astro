---
import ServiceLayout from '../layouts/ServiceLayout.astro';
---

<ServiceLayout
	title='Gestión de E-commerce y Motores de Venta Online'
	description='Administración estratégica de plataformas de venta para aumentar reservas, conversiones y eficiencia operativa.'
>
	<div class='grid gap-6 md:grid-cols-2'>
		<div class='rounded-2xl border border-brand-main/10 bg-white/70 p-6'>
			<h2 class='font-heading text-2xl'>Plataformas gestionadas</h2>
			<p class='mt-3 text-brand-main/80'>FareHarbor, TripAdvisor/Viator, Airbnb, Booking, Open Table, Tiqets, Google Perfil de Negocio y más.</p>
		</div>
		<div class='rounded-2xl border border-brand-main/10 bg-white/70 p-6'>
			<h2 class='font-heading text-2xl'>Operación diaria</h2>
			<p class='mt-3 text-brand-main/80'>Actualización de tarifas, disponibilidad, reseñas, descripciones y material visual para mantener conversión alta.</p>
		</div>
	</div>
</ServiceLayout>
